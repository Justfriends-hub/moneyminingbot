# ─────────────────────────────────────────────
# Crypto Trading Bot — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# Lines starting with # are comments and are ignored.
# Do NOT put spaces around the = sign.
# ─────────────────────────────────────────────

# ── Bybit Exchange API ────────────────────────
# For paper trading: use testnet keys from https://testnet.bybit.com
# For live trading:  use real keys from https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# ── Telegram Bot ──────────────────────────────
# Get a bot token from @BotFather on Telegram (/newbot command)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your numeric Telegram User ID (get it from @userinfobot)
# Multiple users: comma-separated e.g. 123456789,987654321
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# ── Trading Mode ──────────────────────────────
# "paper" = simulated trading (no real money)
# "live"  = real money on Bybit (use with extreme caution)
TRADING_MODE=paper

# Starting paper balance in USDT (min: $5, max: $1000)
PAPER_BALANCE=500

# ── Risk Management ──────────────────────────
# Risk per trade as % of account balance (min: 0.1%, max: 2%)
RISK_PER_TRADE=0.25

# Maximum daily loss as % of starting balance before trading is paused
MAX_DAILY_LOSS_PCT=2.0

# Maximum number of concurrent open positions
MAX_CONCURRENT_TRADES=3

# Minutes to pause after consecutive losses
LOSS_COOLDOWN_MINUTES=30

# ── Strategy Settings ────────────────────────
# "auto" = bot picks the best strategy per market regime
# Or choose one: "trend", "mean_reversion", "breakout"
DEFAULT_STRATEGY=AUTO

# "AUTO" = bot scans all pairs and picks the best setup
# Or specify pairs: "BTC/USDT,ETH/USDT,SOL/USDT"
DEFAULT_PAIRS=AUTO

# Candle timeframe: "15m", "1h", "4h"
DEFAULT_TIMEFRAME=1h

# ── Database ─────────────────────────────────
# Path to SQLite database file (relative to crypto_bot/ directory)
DATABASE_PATH=crypto_bot.db

# ── Logging ──────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to crypto_bot/ directory)
LOG_FILE=bot.log
